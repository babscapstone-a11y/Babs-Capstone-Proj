<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Let requests that already target /public/... pass through untouched
    RewriteCond %{REQUEST_URI} !^/public/

    # Everything else gets transparently served from the public/ subfolder,
    # since this Hostinger plan doesn't allow changing the site's document root.
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
